{
  "expo": {
    "name": "MineralWallet",
    "slug": "mineralwallet",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "mineralwallet",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060A14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mineralwallet.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MineralWallet necesita la cámara para escanear códigos QR de pago",
        "NSLocationWhenInUseUsageDescription": "MineralWallet necesita tu ubicación para el botón SOS de emergencia",
        "NSLocationAlwaysUsageDescription": "MineralWallet necesita tu ubicación para emergencias incluso en segundo plano",
        "NSFaceIDUsageDescription": "Usá Face ID para acceder de forma segura a tu cuenta"
      }
    },
    "android": {
      "package": "com.mineralwallet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060A14"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-font",
      "expo-notifications"
    ]
  }
}
